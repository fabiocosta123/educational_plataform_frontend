{
  "id": "/",
  "name": "Educational Platform",
  "short_name": "EduPlatform",
  "description": "Plataforma educacional responsiva com Next.js e Tailwind",
  "start_url": "/",
  "display": "standalone",
  "display_override": ["standalone","window-controls-overlay"],
  "background_color": "#ffffff",
  "theme_color": "#2563eb",
  "icons": [
    {
      "src": "/icons/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
     {
      "src": "/icons/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any" 
    },
    {
      "src": "/icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable" 
    }
  ],
  "screenshots": [
  {
    "src": "/screenshots/desktop.png",
    "sizes": "1280x720",
    "type": "image/png",
    "form_factor": "wide"
  },
  {
    "src": "/screenshots/mobile.png",
    "sizes": "720x1280",
    "type": "image/png"
  }
],
"protocol_handlers": [
  {
    "protocol": "web+edu",
    "url": "/?q=%s"
  }
]
}
